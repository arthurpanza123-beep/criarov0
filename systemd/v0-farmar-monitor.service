[Unit]
Description=v0 Farm Console - operational health monitor (criarov0)
# Independent of any other project's services on this host.
After=postgresql.service
Wants=postgresql.service

[Service]
Type=oneshot
User=panza
WorkingDirectory=/home/panza/v0 farmar
ExecStart=/home/panza/.nvm/versions/node/v24.18.0/bin/node --conditions=react-server --import tsx scripts/health-monitor.ts
Environment=NODE_ENV=production
TimeoutStartSec=60
Nice=5

[Install]
WantedBy=multi-user.target
