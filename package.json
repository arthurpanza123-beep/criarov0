{
  "name": "v0-farm-console",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "test": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration --config vitest.config.ts",
    "typecheck": "tsc --noEmit",
    "worker": "node --conditions=react-server --import tsx scripts/worker.ts",
    "test:e2e": "playwright test",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "tsx lib/db/seed.ts",
    "db:studio": "drizzle-kit studio",
    "db:check": "drizzle-kit check",
    "auth:bootstrap-owner": "tsx scripts/auth-bootstrap-owner.ts"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@vercel/analytics": "1.6.1",
    "better-auth": "^1.6.23",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^1.16.0",
    "motion": "^12.42.2",
    "next": "16.2.6",
    "postgres": "^3.4.9",
    "react": "^19",
    "react-dom": "^19",
    "server-only": "^0.0.1",
    "shadcn": "^4.8.0",
    "tailwind-merge": "^3.3.1",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "@tailwindcss/postcss": "^4.2.0",
    "@types/node": "^24",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.9",
    "postcss": "^8.5",
    "tailwindcss": "^4.2.0",
    "tsx": "^4.22.4",
    "typescript": "5.7.3",
    "vitest": "^4.1.9"
  },
  "pnpm": {
    "overrides": {
      "hono": "4.12.25"
    }
